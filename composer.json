{
    "name": "somnambulist/query-builder",
    "description": "An object-oriented query builder for programmatically generating SQL queries",
    "keywords": [
        "query",
        "builder",
        "sql"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Dave Redfern",
            "email": "info@somnambulist.tech"
        }
    ],
    "type": "library",
    "require": {
        "php": ">=8.4",
        "psr/event-dispatcher": "^1.0",
        "psr/log": "^1|^2|^3"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.4",
        "doctrine/dbal": "^4.0",
        "somnambulist/domain": "^7.0",
        "symfony/event-dispatcher": "^7.0|^8.0",
        "symfony/var-dumper": "^7.0|^8.0",
        "symfony/stopwatch": "^7.0|^8.0",
        "symfony/yaml": "^7.0|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Somnambulist\\Components\\QueryBuilder\\": "src/"
        },
        "files": [
            "src/Resources/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Somnambulist\\Components\\QueryBuilder\\Tests\\": "tests/"
        }
    },
    "suggest": {
        "symfony/event-dispatcher": "Required for the configurators"
    }
}
